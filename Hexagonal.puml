@startuml HexagonalArchitecture

title Ayvalık Bank CC-1 — Hexagonal Architecture

left to right direction

skinparam defaultFontSize 11
skinparam defaultFontName Arial
skinparam shadowing false
skinparam linetype polyline
skinparam packageStyle rectangle

skinparam package {
    BackgroundColor<<inbound>>   #D8E8FF
    BorderColor<<inbound>>       #2255AA
    FontColor<<inbound>>         #2255AA
    BackgroundColor<<outbound>>  #D8F5D8
    BorderColor<<outbound>>      #226622
    FontColor<<outbound>>        #226622
    BackgroundColor<<port_in>>   #EAF3FF
    BorderColor<<port_in>>       #4488CC
    BackgroundColor<<port_out>>  #EAFAEA
    BorderColor<<port_out>>      #44AA44
    BackgroundColor<<app>>       #FFF8D8
    BorderColor<<app>>           #AA8800
    BackgroundColor<<domain>>    #FFE8E8
    BorderColor<<domain>>        #CC2222
    BackgroundColor<<hexagon>>   #FFFAF0
    BorderColor<<hexagon>>       #CC6600
    FontColor<<hexagon>>         #CC6600
}
skinparam component {
    BackgroundColor<<ctrl>>      #C8DCFF
    BorderColor<<ctrl>>          #2255AA
    BackgroundColor<<svc>>       #FFEEBB
    BorderColor<<svc>>           #AA8800
    BackgroundColor<<adapter>>   #C8F5C8
    BorderColor<<adapter>>       #226622
    BackgroundColor<<security>>  #EEDDFF
    BorderColor<<security>>      #664488
    BackgroundColor<<interface>> #FFFFFF
    BorderColor<<interface>>     #888888
    BackgroundColor<<entity>>    #DDEEFF
    BorderColor<<entity>>        #3366AA
    BackgroundColor<<record>>    #EEFFDD
    BorderColor<<record>>        #336633
    BackgroundColor<<service>>   #FFF5CC
    BorderColor<<service>>       #AA8800
    BackgroundColor<<enum>>      #F5F5F5
    BorderColor<<enum>>          #777777
}
skinparam database {
    BackgroundColor #F0F0F0
    BorderColor     #555555
}
skinparam actor {
    BackgroundColor #D8E8FF
    BorderColor     #2255AA
}

' ════════════════════════════════════════════════
' HTTP CLIENTS
' ════════════════════════════════════════════════
actor Admin
actor Customer

' ════════════════════════════════════════════════
' INBOUND ADAPTERS
' ════════════════════════════════════════════════
package "Inbound Adapters" <<inbound>> {
    component [Security Filter\nBankUserDetailsService]   <<security>> as SEC
    component [AdminController\n/api/admin/**]            <<ctrl>>     as ADMIN
    component [CustomerController\n/api/customers/**]     <<ctrl>>     as CUST
    component [AccountController\n/api/accounts/**]       <<ctrl>>     as ACC
    component [GlobalExceptionHandler]                    <<ctrl>>     as EXC
}

' ════════════════════════════════════════════════
' THE HEXAGON
' ════════════════════════════════════════════════
package "« T H E   H E X A G O N »" <<hexagon>> {

    ' ── PORTS IN ───────────────────────────────
    package "Ports In  (Driving / Inbound)" <<port_in>> {
        component [CreateCustomerUseCase]   <<interface>> as UC_CC
        component [DeleteCustomerUseCase]   <<interface>> as UC_DC
        component [ListCustomersUseCase]    <<interface>> as UC_LC
        component [ChangePasswordUseCase]   <<interface>> as UC_CP
        component [SetTransferFeeUseCase]   <<interface>> as UC_SF
        component [CreateAccountUseCase]    <<interface>> as UC_CA
        component [DepositMoneyUseCase]     <<interface>> as UC_DM
        component [WithdrawMoneyUseCase]    <<interface>> as UC_WM
        component [GetBalanceUseCase]       <<interface>> as UC_GB
        component [GetTransactionsUseCase]  <<interface>> as UC_GT
        component [ListAccountsUseCase]     <<interface>> as UC_LA
        component [TransferMoneyUseCase]    <<interface>> as UC_TM
        component [FreezeAccountUseCase]    <<interface>> as UC_FA
        component [UnfreezeAccountUseCase]  <<interface>> as UC_UA
        component [CloseAccountUseCase]     <<interface>> as UC_XA
    }

    ' ── APPLICATION LAYER ───────────────────────
    package "Application Layer" <<app>> {
        component [CustomerApplicationService\n@Service  @Transactional] <<svc>> as CSVC
        component [AccountApplicationService\n@Service  @Transactional]  <<svc>> as ASVC
        note right of CSVC
          Orchestrates domain + ports out.
          No business rules here.
        end note
    }

    ' ── DOMAIN LAYER ───────────────────────────
    package "Domain Layer  (pure Java — no framework)" <<domain>> {

        package "Entities" <<domain>> {
            component [Customer]    <<entity>> as ENT_C
            component [Account]     <<entity>> as ENT_A
            component [Transaction] <<entity>> as ENT_T
        }

        package "Value Objects" <<domain>> {
            component [Money]          <<record>> as VO_M
            component [Password]       <<record>> as VO_P
            component [CustomerId]     <<record>> as VO_CI
            component [AccountId]      <<record>> as VO_AI
            component [TransactionId]  <<record>> as VO_TI
            component [Currency]       <<enum>>   as VO_CY
            component [TransactionType]<<enum>>   as VO_TT
            component [AccountStatus]  <<enum>>   as VO_AS
        }

        package "Domain Services" <<domain>> {
            component [PasswordValidationService] <<service>> as DS_PV
            component [TransferDomainService]     <<service>> as DS_TD
        }
    }

    ' ── PORTS OUT ──────────────────────────────
    package "Ports Out  (Driven / Outbound)" <<port_out>> {
        component [CustomerRepositoryPort]    <<interface>> as PO_CR
        component [AccountRepositoryPort]     <<interface>> as PO_AR
        component [TransactionRepositoryPort] <<interface>> as PO_TR
        component [PasswordHasherPort]        <<interface>> as PO_PH
        component [SettingsRepositoryPort]    <<interface>> as PO_SR
    }
}

' ════════════════════════════════════════════════
' OUTBOUND ADAPTERS
' ════════════════════════════════════════════════
package "Outbound Adapters" <<outbound>> {
    component [CustomerPersistenceAdapter]    <<adapter>> as CP
    component [AccountPersistenceAdapter]     <<adapter>> as AP
    component [TransactionPersistenceAdapter] <<adapter>> as TP
    component [SettingsPersistenceAdapter]    <<adapter>> as SP
    component [BCryptPasswordHasherAdapter\n(strength 12)] <<adapter>> as BCRYPT
}

' ════════════════════════════════════════════════
' DATABASE
' ════════════════════════════════════════════════
database "PostgreSQL\n──────────────────\ncustomers\npassword_history\naccounts  (+ status)\ntransactions\nsettings" as DB

' ════════════════════════════════════════════════
' CONNECTIONS — INBOUND SIDE
' ════════════════════════════════════════════════
Admin    --> SEC : HTTPS
Customer --> SEC : HTTPS

SEC --> ADMIN
SEC --> CUST
SEC --> ACC

ADMIN --> UC_CC
ADMIN --> UC_DC
ADMIN --> UC_LC
ADMIN --> UC_SF
ADMIN --> UC_FA
ADMIN --> UC_UA
ADMIN --> UC_XA
CUST  --> UC_CP
ACC   --> UC_CA
ACC   --> UC_DM
ACC   --> UC_WM
ACC   --> UC_GB
ACC   --> UC_GT
ACC   --> UC_LA
ACC   --> UC_TM

' ════════════════════════════════════════════════
' APPLICATION SERVICES implement PORTS IN
' ════════════════════════════════════════════════
CSVC ..> UC_CC : implements
CSVC ..> UC_DC : implements
CSVC ..> UC_LC : implements
CSVC ..> UC_CP : implements
CSVC ..> UC_SF : implements

ASVC ..> UC_CA : implements
ASVC ..> UC_DM : implements
ASVC ..> UC_WM : implements
ASVC ..> UC_GB : implements
ASVC ..> UC_GT : implements
ASVC ..> UC_LA : implements
ASVC ..> UC_TM : implements
ASVC ..> UC_FA : implements
ASVC ..> UC_UA : implements
ASVC ..> UC_XA : implements

' ════════════════════════════════════════════════
' APPLICATION SERVICES use DOMAIN
' ════════════════════════════════════════════════
CSVC --> ENT_C
CSVC --> DS_PV
ASVC --> ENT_A
ASVC --> ENT_T
ASVC --> DS_TD
ASVC --> VO_M
ENT_A --> VO_AS
note right of VO_AS
  ACTIVE → FROZEN → ACTIVE
  ACTIVE|FROZEN → CLOSED (terminal)
  deposit / withdraw / transferOut
  / transferIn require ACTIVE
end note

' ════════════════════════════════════════════════
' APPLICATION SERVICES call PORTS OUT
' ════════════════════════════════════════════════
CSVC --> PO_CR
CSVC --> PO_PH
CSVC --> PO_SR
ASVC --> PO_AR
ASVC --> PO_TR
ASVC --> PO_SR

' ════════════════════════════════════════════════
' OUTBOUND ADAPTERS implement PORTS OUT
' ════════════════════════════════════════════════
CP     ..> PO_CR : implements
AP     ..> PO_AR : implements
TP     ..> PO_TR : implements
SP     ..> PO_SR : implements
BCRYPT ..> PO_PH : implements

' ════════════════════════════════════════════════
' OUTBOUND ADAPTERS → DATABASE
' ════════════════════════════════════════════════
CP --> DB
AP --> DB
TP --> DB
SP --> DB

' ════════════════════════════════════════════════
' DEPENDENCY RULE NOTE
' ════════════════════════════════════════════════
note bottom of DB
  All dependencies point INWARD.
  Domain Layer imports NOTHING
  from Spring, JPA, or BCrypt.
end note

@enduml

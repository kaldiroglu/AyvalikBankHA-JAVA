@startuml Domain

title Ayvalık Bank CC-1 — Domain Layer\ndev.kaldiroglu.hexagonal.ayvalikbank.domain

skinparam packageStyle rectangle
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam linetype ortho

skinparam class {
    BackgroundColor White
    BorderColor #555
    ArrowColor #333
    FontSize 11
}
skinparam stereotype {
    CBackgroundColor<<entity>>  #DDEEFF
    CBorderColor<<entity>>      #3366AA
    CBackgroundColor<<record>>  #EEFFDD
    CBorderColor<<record>>      #336633
    CBackgroundColor<<service>> #FFF5CC
    CBorderColor<<service>>     #AA8800
}

' ─────────────────────────────────────────
' PACKAGE: domain.model
' ─────────────────────────────────────────
package "domain.model" {

    enum Currency {
        USD
        EUR
        TL
    }

    enum TransactionType {
        DEPOSIT
        WITHDRAWAL
        TRANSFER_OUT
        TRANSFER_IN
    }

    enum AccountStatus {
        ACTIVE
        FROZEN
        CLOSED
        ..state machine..
        ACTIVE → FROZEN (freeze)
        FROZEN → ACTIVE (unfreeze)
        ACTIVE|FROZEN → CLOSED (close)
        CLOSED is terminal
    }

    class CustomerId <<record>> {
        + UUID value
        --
        + {static} CustomerId generate()
        + {static} CustomerId of(UUID)
        + {static} CustomerId of(String)
    }

    class AccountId <<record>> {
        + UUID value
        --
        + {static} AccountId generate()
        + {static} AccountId of(UUID)
        + {static} AccountId of(String)
    }

    class TransactionId <<record>> {
        + UUID value
        --
        + {static} TransactionId generate()
        + {static} TransactionId of(UUID)
    }

    class Password <<record>> {
        + String hashedValue
        --
        + {static} Password ofHashed(String)
    }

    class Money <<record>> {
        + BigDecimal amount
        + Currency currency
        --
        + {static} Money of(BigDecimal, Currency)
        + {static} Money of(double, Currency)
        + {static} Money zero(Currency)
        + Money add(Money)
        + Money subtract(Money)
        + Money multiply(BigDecimal)
        + boolean isGreaterThanOrEqualTo(Money)
    }

    class Customer <<entity>> {
        - CustomerId id
        - String name
        - String email
        - String role
        - Password currentPassword
        - List<Password> passwordHistory
        --
        + {static} Customer create(String, String, Password)
        + void changePassword(Password)
        + List<Password> getAllPasswordsForReuseCheck()
        + CustomerId getId()
        + String getName()
        + String getEmail()
        + String getRole()
        + Password getCurrentPassword()
        + List<Password> getPasswordHistory()
    }

    class Account <<entity>> {
        - AccountId id
        - CustomerId ownerId
        - Currency currency
        - Money balance
        - AccountStatus status
        --
        + {static} Account open(CustomerId, Currency)
        .. operations (require ACTIVE) ..
        + Transaction deposit(Money)
        + Transaction withdraw(Money)
        + Transaction transferOut(Money, Money, String)
        + Transaction transferIn(Money, String)
        .. status transitions ..
        + void freeze()
        + void unfreeze()
        + void close()
        .. accessors ..
        + AccountId getId()
        + CustomerId getOwnerId()
        + Currency getCurrency()
        + Money getBalance()
        + AccountStatus getStatus()
    }

    class Transaction <<entity>> {
        - TransactionId id
        - AccountId accountId
        - TransactionType type
        - Money amount
        - LocalDateTime timestamp
        - String description
        --
        + {static} Transaction create(AccountId, TransactionType, Money, String)
        + TransactionId getId()
        + AccountId getAccountId()
        + TransactionType getType()
        + Money getAmount()
        + LocalDateTime getTimestamp()
        + String getDescription()
    }

    Customer    "1" *-right- "1"    CustomerId    : id
    Customer    "1" *-down-  "1"    Password      : currentPassword
    Customer    "1" *-down-  "0..3" Password      : passwordHistory
    Account     "1" *-right- "1"    AccountId     : id
    Account     "1" *-down-  "1"    Money         : balance
    Account     "1" o-right- "1"    CustomerId    : ownerId
    Account     "1" o-right- "1"    Currency
    Account     "1" *-down-  "1"    AccountStatus : status
    Transaction "1" *-right- "1"    TransactionId : id
    Transaction "1" *-down-  "1"    Money         : amount
    Transaction "1" o-right- "1"    AccountId     : accountId
    Transaction "1" o-right- "1"    TransactionType
    Money       "1" o-right- "1"    Currency
}

' ─────────────────────────────────────────
' PACKAGE: domain.service
' ─────────────────────────────────────────
package "domain.service" {

    class PasswordValidationService <<service>> {
        + void validate(String rawPassword)
    }

    class TransferDomainService <<service>> {
        + Money calculateFee(Money, boolean, BigDecimal)
    }
}

TransferDomainService ..> Money : "returns"

' ─────────────────────────────────────────
' PACKAGE: domain.port.in  (Use Cases)
' Command records are nested classes shown
' with +-- (inner class) relationship.
' ─────────────────────────────────────────
package "domain.port.in" {

    interface CreateCustomerUseCase {
        + Customer createCustomer(Command)
    }
    class CreateCustomerCommand <<record>> {
        + String name
        + String email
        + String rawPassword
    }
    CreateCustomerUseCase +-- CreateCustomerCommand

    interface DeleteCustomerUseCase {
        + void deleteCustomer(CustomerId)
    }

    interface ListCustomersUseCase {
        + List<Customer> listCustomers()
    }

    interface ChangePasswordUseCase {
        + void changePassword(Command)
    }
    class ChangePasswordCommand <<record>> {
        + CustomerId customerId
        + String rawNewPassword
    }
    ChangePasswordUseCase +-- ChangePasswordCommand

    interface CreateAccountUseCase {
        + Account createAccount(Command)
    }
    class CreateAccountCommand <<record>> {
        + CustomerId ownerId
        + Currency currency
    }
    CreateAccountUseCase +-- CreateAccountCommand

    interface DepositMoneyUseCase {
        + Transaction deposit(Command)
    }
    class DepositMoneyCommand <<record>> {
        + AccountId accountId
        + Money amount
    }
    DepositMoneyUseCase +-- DepositMoneyCommand

    interface WithdrawMoneyUseCase {
        + Transaction withdraw(Command)
    }
    class WithdrawMoneyCommand <<record>> {
        + AccountId accountId
        + Money amount
    }
    WithdrawMoneyUseCase +-- WithdrawMoneyCommand

    interface GetBalanceUseCase {
        + Money getBalance(AccountId)
    }

    interface GetTransactionsUseCase {
        + List<Transaction> getTransactions(AccountId)
    }

    interface ListAccountsUseCase {
        + List<Account> listAccounts(CustomerId)
    }

    interface TransferMoneyUseCase {
        + void transfer(Command)
    }
    class TransferMoneyCommand <<record>> {
        + AccountId sourceAccountId
        + AccountId targetAccountId
        + Money amount
    }
    TransferMoneyUseCase +-- TransferMoneyCommand

    interface SetTransferFeeUseCase {
        + void setTransferFee(Command)
    }
    class SetTransferFeeCommand <<record>> {
        + BigDecimal feePercent
    }
    SetTransferFeeUseCase +-- SetTransferFeeCommand

    interface FreezeAccountUseCase {
        + void freezeAccount(AccountId)
    }

    interface UnfreezeAccountUseCase {
        + void unfreezeAccount(AccountId)
    }

    interface CloseAccountUseCase {
        + void closeAccount(AccountId)
    }
}

' ─────────────────────────────────────────
' PACKAGE: domain.port.out
' ─────────────────────────────────────────
package "domain.port.out" {

    interface CustomerRepositoryPort {
        + Customer save(Customer)
        + Optional<Customer> findById(CustomerId)
        + Optional<Customer> findByEmail(String)
        + List<Customer> findAll()
        + void deleteById(CustomerId)
        + boolean existsById(CustomerId)
    }

    interface AccountRepositoryPort {
        + Account save(Account)
        + Optional<Account> findById(AccountId)
        + List<Account> findByOwnerId(CustomerId)
        + boolean existsById(AccountId)
    }

    interface TransactionRepositoryPort {
        + Transaction save(Transaction)
        + List<Transaction> findByAccountId(AccountId)
    }

    interface PasswordHasherPort {
        + String hash(String rawPassword)
        + boolean matches(String rawPassword, String hashedPassword)
    }

    interface SettingsRepositoryPort {
        + BigDecimal getTransferFeePercent()
        + void setTransferFeePercent(BigDecimal)
    }
}

' ─────────────────────────────────────────
' Cross-package dependencies
' ─────────────────────────────────────────
CreateCustomerUseCase  ..> Customer     : "returns"
ListCustomersUseCase   ..> Customer     : "returns"
DeleteCustomerUseCase  ..> CustomerId   : "uses"
ChangePasswordUseCase  ..> CustomerId   : "uses"
CreateAccountUseCase   ..> Account      : "returns"
ListAccountsUseCase    ..> Account      : "returns"
DepositMoneyUseCase    ..> Transaction  : "returns"
WithdrawMoneyUseCase   ..> Transaction  : "returns"
GetBalanceUseCase      ..> Money        : "returns"
GetTransactionsUseCase ..> Transaction  : "returns"
TransferMoneyUseCase   ..> AccountId    : "uses"
FreezeAccountUseCase   ..> AccountId    : "uses"
UnfreezeAccountUseCase ..> AccountId    : "uses"
CloseAccountUseCase    ..> AccountId    : "uses"

CustomerRepositoryPort    ..> Customer    : "manages"
AccountRepositoryPort     ..> Account     : "manages"
TransactionRepositoryPort ..> Transaction : "manages"

@enduml
